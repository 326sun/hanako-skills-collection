# Auto-detect text files, normalize to LF
*       text=auto eol=lf

# Explicit text types
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.ps1   text eol=lf
*.sh    text eol=lf
*.py    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf

# Binary types
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.pdf   binary
*.zip   binary
*.skill binary
